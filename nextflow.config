/*
 * Nextflow config for FD-7263 MRE
 */

manifest {
    name            = 'FD-7263-template-display-issue'
    author          = 'Seqera Support'
    description     = 'MRE demonstrating template directive display issue in Platform'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
}

// Process configuration
process {
    // Use local executor for testing
    executor = 'local'
}

// Enable execution report
report {
    enabled = true
    overwrite = true
}

timeline {
    enabled = true
    overwrite = true
}

trace {
    enabled = true
    overwrite = true
}
